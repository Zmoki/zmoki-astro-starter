# PostHog analytics (leave blank to disable)
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=

# Google Tag Manager container ID, e.g. GTM-XXXXXXX (leave blank to disable)
PUBLIC_GTM_CONTAINER_ID=

# Set to "false" to disable ALL analytics providers (e.g. in dev)
PUBLIC_ANALYTICS_ENABLED=

# Brevo email forms
PUBLIC_BREVO_ACCOUNT_ID=

# Captcha — built-in provider is Cloudflare Turnstile (bot protection on forms).
# Provider-agnostic: see src/components/Captcha.astro to swap in reCAPTCHA/hCaptcha.
PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=

# Set to "false" to disable the form captcha (e.g. in dev)
PUBLIC_CAPTCHA_ENABLED=

# Remote image origin for content images — DECOUPLED from the deploy host. Base
# URL of where originals live, e.g. an R2 bucket on a custom domain. Images are
# optimized AT BUILD by Astro and served by the deploy host (the origin is pure
# storage). Setting this authorizes the domain for build-time optimization and
# lets content reference images by bare key. Leave blank to commit images to
# src/images instead. See src/image.config.ts and the /images skill.
PUBLIC_IMAGE_CDN_BASE=
