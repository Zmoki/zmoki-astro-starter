{
  "name": "zmoki-astro-starter",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prebuild": "npm run build:redirects && npm run build:headers",
    "build:redirects": "node scripts/generate-redirects.ts",
    "build:headers": "node scripts/generate-headers.ts",
    "check:redirects": "node scripts/generate-redirects.ts && (git diff --exit-code -- public/_redirects vercel.json redirects.json || (echo '\\n✖ Redirect artifacts are out of date. Run: npm run build:redirects, then commit the result.' && exit 1))",
    "check:headers": "node scripts/generate-headers.ts && (git diff --exit-code -- public/_headers vercel.json customHeaders.json || (echo '\\n✖ Header artifacts are out of date. Run: npm run build:headers, then commit the result.' && exit 1))",
    "check": "astro check",
    "check:sd": "node scripts/check-structured-data.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules",
    "timeline:blog": "node scripts/generate-blog-timeline.mjs",
    "lhci:mobile": "lhci autorun --collect.settings.chromeFlags='--headless' --collect.settings.emulatedFormFactor=mobile",
    "lhci:desktop": "lhci autorun --collect.settings.chromeFlags='--headless' --collect.settings.emulatedFormFactor=desktop",
    "lhci:collect": "lhci collect",
    "lhci:assert": "lhci assert"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.14",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "culori": "^4.0.2",
    "markdown-it": "^14.1.0",
    "posthog-js": "^1.376.5",
    "remark-definition-list": "^2.0.0",
    "sanitize-html": "^2.17.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.2",
    "unist-util-visit": "^5.0.0",
    "unist-util-visit-parents": "^6.0.2"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource/noto-sans": "^5.2.10",
    "@lhci/cli": "^0.15.1",
    "@types/culori": "^4.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
