---
// Reusable button, composed from Tailwind utilities. Renders an <a> when `href`
// is given (a button-like link) or a <button> otherwise. Extra classes passed
// via `class` are appended, and any other attributes (e.g. `target`, `data-*`,
// `aria-*`) pass straight through.
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "inverse";
  size?: "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  class: extra = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-lg font-semibold shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-zmoki-indigo-500 focus:ring-offset-2";

const sizes = {
  md: "px-4 py-2 text-sm",
  lg: "px-6 py-3 text-base",
};

const variants = {
  primary: "bg-zmoki-indigo-600 text-white hover:bg-zmoki-indigo-700",
  secondary:
    "border border-zmoki-stone-300 bg-white text-zmoki-stone-900 hover:border-zmoki-stone-400 hover:bg-zmoki-stone-50",
  inverse: "bg-white text-zmoki-indigo-700 hover:bg-zmoki-indigo-50",
};

const classes = [base, sizes[size], variants[variant], extra].filter(Boolean).join(" ");
---

{
  href ? (
    <a href={href} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
