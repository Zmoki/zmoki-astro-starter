---
// Captcha dispatcher, mirroring Analytics.astro but single-select: at most ONE
// provider renders (two widgets would inject competing hidden tokens), the
// first in `providers` whose site-key constant is set. The active provider's
// token is validated by the form backend (Brevo) against the captcha
// configured on that Brevo form — keep the two in sync.
//
// Off by default everywhere and on only for the host's real production build
// of `main` (see isProductionDeploy) — this also conveniently keeps Turnstile's
// domain check from tripping in local dev / CI / previews.
// PUBLIC_CAPTCHA_ENABLED overrides that default when explicitly "true" or
// "false"; leave it unset to just use the automatic default.
// To add a provider: create a component exporting its own site-key constant,
// import it, add a { enabled, Component } entry below, and allowlist its host
// in src/headers/headers.config.ts (then `npm run build:headers`).
import { site } from "@/site.config";
import { isProductionDeploy } from "@/lib/deploy";
import Turnstile, { TURNSTILE_SITE_KEY } from "@/components/captcha/turnstile.astro";

const captchaOverride = import.meta.env.PUBLIC_CAPTCHA_ENABLED;
const captchaEnabled = captchaOverride
  ? captchaOverride !== "false"
  : isProductionDeploy(site.platform.deploy);

// Priority order: the first provider with its site key set wins.
const providers = [{ enabled: !!TURNSTILE_SITE_KEY, Component: Turnstile }];

const Active = captchaEnabled ? providers.find((p) => p.enabled)?.Component : undefined;
---

{Active && <Active />}
