---
// Captcha dispatcher, mirroring Analytics.astro but single-select: at most ONE
// provider renders (two widgets inject competing hidden tokens), the first in
// `providers` whose site-key constant is set. Its token is validated by the
// form backend (Brevo) against the captcha configured on that Brevo form —
// keep the two in sync.
//
// Off by default; PUBLIC_CAPTCHA_ENABLED="true" turns it on (host's production
// env, CI on main, or locally to test) — also keeps Turnstile's domain check
// from tripping in local dev.
// To add a provider: export a site-key constant, add a { enabled, Component }
// entry below, and allowlist its host in src/headers/headers.config.ts.
import Turnstile, { TURNSTILE_SITE_KEY } from "@/components/captcha/turnstile.astro";

const captchaEnabled = import.meta.env.PUBLIC_CAPTCHA_ENABLED === "true";

// Priority order: the first provider with its site key set wins.
const providers = [{ enabled: !!TURNSTILE_SITE_KEY, Component: Turnstile }];

const Active = captchaEnabled ? providers.find((p) => p.enabled)?.Component : undefined;
---

{Active && <Active />}
