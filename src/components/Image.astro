---
// Vendor-neutral responsive image. Everything is optimized at build by Astro
// (astro:assets): a repo-committed asset (imported ImageMetadata) or a
// remote-hosted image (a string key/URL whose origin is authorized in
// astro.config.mjs `image.remotePatterns`). Astro downloads + resizes +
// re-encodes to webp/avif, content-hashes into dist/_astro, and the deploy host
// serves it. No runtime image-CDN transform — see src/image.config.ts.
//
// A string `src` is resolved against the image origin (bare key → full URL) and
// REQUIRES width + height (Astro can't infer a remote image's dimensions). An
// image on an unauthorized origin renders as-is (unoptimized) rather than
// failing the build.
import { Image as AstroImage } from "astro:assets";
import { resolveImageSrc, type ImageLayout } from "@/image.config";

interface Props {
  /** An imported asset (local) or a remote key/URL (string). */
  src: ImageMetadata | string;
  alt: string;
  /** Required for a string (remote) src. */
  width?: number;
  height?: number;
  layout?: ImageLayout;
  /** Eager-load + fetchpriority=high — set on the LCP/hero image only. */
  priority?: boolean;
  sizes?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  src,
  alt,
  width,
  height,
  layout = "constrained",
  priority = false,
  sizes,
  class: className,
  ...rest
} = Astro.props;

const resolvedSrc = typeof src === "string" ? resolveImageSrc(src) : src;
// Astro spells full-width with a hyphen.
const astroLayout = layout === "fullWidth" ? "full-width" : layout;
---

<AstroImage
  src={resolvedSrc}
  alt={alt}
  width={width ?? (typeof src === "object" ? src.width : undefined)}
  height={height}
  layout={astroLayout}
  loading={priority ? "eager" : "lazy"}
  {...priority ? { fetchpriority: "high" } : {}}
  {...sizes ? { sizes } : {}}
  class={className}
  {...rest}
/>
