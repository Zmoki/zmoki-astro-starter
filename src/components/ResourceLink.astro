---
import { getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";

export interface Props {
  slug: string;
  class: string;
}

const { slug, class: className } = Astro.props;

const resource = await getEntry("resources", slug);
if (!resource) throw new Error(`Resource not found: ${slug}`);

const href = resource.data.type === "link" ? resource.data.url : `/resources/${slug}/`;
---

<a
  href={href}
  data-resource="true"
  data-resource-slug={slug}
  data-resource-external={resource.data.type === "link" ? "true" : "false"}
  class={className}
>
  <slot set:html={resource.data.name} />
</a>

<!--
  This component may render many times per page, so track clicks with a single
  delegated listener registered once (guarded by a window flag) — binding a
  per-instance handler that queried all resource links would fire the event N
  times per click on a page with N ResourceLinks.
-->
<script is:inline>
  if (!window.__resourceLinkTracking) {
    window.__resourceLinkTracking = true;
    document.addEventListener("click", function (e) {
      var el = e.target.closest && e.target.closest('a[data-resource="true"]');
      if (!el) return;
      window.track?.("resource_link_clicked", {
        resource_slug: el.dataset.resourceSlug,
        is_external: el.dataset.resourceExternal === "true",
      });
    });
  }
</script>
