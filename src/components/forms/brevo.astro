---
// Brevo email-capture provider (the built-in resource-gate form). Selected by
// Form.astro (the dispatcher). Renders a native HTML form that POSTs to Brevo's
// hosted endpoint; Brevo validates the captcha token, stores the contact, emails
// the lead-magnet asset, and redirects to the thank-you page (all configured on
// the Brevo form). The <Captcha /> and the resource_gate_* analytics are the
// shared, vendor-neutral bits.
export interface Props {
  formId: string;
  buttonText?: string;
  resourceSlug?: string;
}

import Button from "@/components/Button.astro";
import Captcha from "@/components/Captcha.astro";

// Brevo account ID for the email signup forms.
const BREVO_ACCOUNT_ID = "75687697";

const defaultButtonText = "Subscribe";
const { formId, buttonText = defaultButtonText, resourceSlug = "" } = Astro.props;
---

<!-- Main form -->
<form
  id="brevo-form"
  method="POST"
  action={`https://${BREVO_ACCOUNT_ID}.sibforms.com/serve/${formId}`}
  class="border-zmoki-stone-200 flex flex-col gap-4 rounded-2xl border bg-white px-4 py-8 shadow-sm md:flex-row md:gap-8 md:p-8 xl:gap-12 xl:p-12"
>
  <section class="prose prose-headings:font-semibold !leading-tight md:w-1/2">
    <slot />
  </section>

  <section class="flex min-w-[300px] flex-1 flex-col gap-4 md:pt-2">
    <!-- Email input -->
    <label for="EMAIL" class="text-xl font-medium">Email</label>
    <input
      type="email"
      id="EMAIL"
      name="EMAIL"
      placeholder="your@email.com"
      required
      class="border-zmoki-stone-300 focus:border-zmoki-indigo-500 focus:ring-zmoki-indigo-500/30 w-full rounded-lg border p-2 text-lg focus:ring-2 focus:outline-none"
    />

    <!-- Captcha (provider-agnostic; see src/components/Captcha.astro) -->
    <Captcha />

    <!-- Legal consent checkbox -->
    <div class="flex w-full items-start gap-2">
      <input
        type="checkbox"
        id="consent"
        name="consent"
        required
        class="border-zmoki-stone-400 text-zmoki-indigo-600 focus:ring-zmoki-indigo-500 mt-1 h-4 w-4 rounded"
      />
      <label for="consent" class="text-zmoki-stone-500 text-xs">
        By checking this box, I acknowledge that I have read, understood, and agree to the <a
          href="/legal/terms/"
          class="text-zmoki-indigo-600 underline underline-offset-2"
          target="_blank">Terms of Service</a
        > and <a
          href="/legal/privacy/"
          class="text-zmoki-indigo-600 underline underline-offset-2"
          target="_blank">Privacy Policy</a
        >.
      </label>
    </div>

    <!-- Submit button -->
    <Button type="submit"><Fragment set:html={buttonText} /></Button>

    <!-- Hidden inputs -->
    <input type="text" name="email_address_check" value="" style="display: none;" />
    <input type="hidden" name="locale" value="en" />
  </section>
</form>

<script is:inline define:vars={{ resourceSlug }}>
  window.track?.("resource_gate_viewed", {
    resource_slug: resourceSlug,
    form_id: document.getElementById("brevo-form")?.getAttribute("action") || "",
  });

  document.getElementById("brevo-form")?.addEventListener("submit", function () {
    var email = document.getElementById("EMAIL")?.value || "";
    window.identify?.(email);
    window.track?.("resource_gate_submitted", {
      form_id: this.getAttribute("action") || "",
      resource_slug: resourceSlug,
    });
  });
</script>
