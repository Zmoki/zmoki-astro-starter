---
import "@/styles/global.css";
import { Font } from "astro:assets";
import { fonts } from "@/design-tokens.mjs";
import Analytics from "@/components/Analytics.astro";
import Button from "@/components/Button.astro";
import { site } from "@/site.config";
import { getOgImage } from "@/og/manifest";
import { siteUrls } from "@/lib/urls";

export interface Props {
  title: string;
  description?: string;
  publishDate?: Date;
  contentModifiedDate?: Date;
  /**
   * When true, <main> spans the full viewport width so the page can render
   * full-bleed landing sections that manage their own inner containers.
   * Default false = a centered, readable container for articles and pages.
   */
  wide?: boolean;
  /**
   * Controls the <link rel="canonical"> tag. Default `true` emits the page's
   * own absolute URL. Pass `false` to emit no canonical (e.g. the 404 page),
   * or a URL string to point the canonical elsewhere — e.g. a post that
   * republishes content whose canonical source lives on another site.
   */
  canonical?: boolean | string;
}

const {
  title,
  description = site.description,
  publishDate,
  contentModifiedDate,
  wide = false,
  canonical = true,
} = Astro.props;

const pagePathname = Astro.url.pathname;
const isPageArticle = publishDate && contentModifiedDate;

// All absolute URLs (canonical, OG, structured data) come from one helper so
// they can't drift apart — see src/lib/urls.ts.
const urls = siteUrls(Astro);
// The page's own absolute URL — used for og:url and, unless overridden, the
// canonical link. `canonical` resolves to: false → no canonical link;
// a string → that URL; true (default) → the page's own URL.
const selfURL = urls.absoluteUrl(pagePathname);
const canonicalURL =
  canonical === false ? null : typeof canonical === "string" ? canonical : selfURL;

// OG image (+ alt) for this page, from the manifest. Generated on the fly by
// /og/[...path].png.ts — see src/og/. Falls back to the site's default card.
const ogImage = await getOgImage(pagePathname);
const pageImageUrl = urls.currentAbsoluteUrl(ogImage.path);

// Bare host (no protocol) for the footer copyright link, e.g. "zmoki.xyz".
const ownerSiteLabel = new URL(site.organization.url).host;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Favicons — generated by `npm run favicons` (scripts/generate-favicons.ts) -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/brand-mark.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <Font cssVariable={fonts.sans.variable} preload />
    <Font cssVariable={fonts.mono.variable} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed"
      href={urls.absoluteUrl("/rss.xml")}
    />

    <!-- Open Graph meta tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={selfURL} />
    <meta property="og:type" content={isPageArticle ? "article" : "website"} />
    <meta property="og:site_name" content={site.ogSiteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={pageImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImage.alt} />
    {
      isPageArticle && (
        <meta property="article:published_time" content={publishDate.toISOString()} />
      )
    }
    {
      isPageArticle && (
        <meta property="article:modified_time" content={contentModifiedDate.toISOString()} />
      )
    }
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content={pageImageUrl} />
    <meta property="twitter:image:alt" content={ogImage.alt} />

    <Analytics />
  </head>
  <body
    class="bg-zmoki-cream-100 text-zmoki-stone-900 flex min-h-full flex-col font-sans text-lg leading-normal tracking-tight xl:text-xl"
  >
    <!-- Top navigation -->
    <header
      class="border-zmoki-stone-200 bg-zmoki-cream-100/80 sticky top-0 z-40 border-b backdrop-blur-md"
    >
      <nav
        class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-4 lg:px-8"
      >
        <a href="/" class="flex items-center" aria-label={`${site.name} — home`}>
          <img
            src="/brand-mark.svg"
            alt={site.name}
            width="36"
            height="36"
            class="size-9 rounded-lg"
          />
        </a>
        <div class="flex items-center gap-4 md:gap-6">
          <ul class="hidden items-center gap-6 md:flex">
            {
              site.nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-zmoki-stone-600 hover:text-zmoki-stone-900 text-sm font-medium transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <Button href={site.social.github}>Get started</Button>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class:list={["w-full flex-1", !wide && "mx-auto max-w-4xl px-4 py-10 lg:py-16"]}>
      <slot />
    </main>

    <script is:inline>
      document.querySelector('a[href^="mailto:"]')?.addEventListener("click", function () {
        window.track?.("contact_email_clicked", {
          email: this.getAttribute("href").replace("mailto:", ""),
        });
      });
    </script>

    <!-- Footer -->
    <footer class="border-zmoki-stone-200 border-t bg-white">
      <div
        class="text-zmoki-stone-500 mx-auto flex w-full max-w-6xl flex-col gap-4 px-4 py-8 text-sm md:flex-row md:items-center md:justify-between lg:px-8"
      >
        <p>
          &copy; {site.copyright.year} · {site.organization.name} ·{" "}
          <a href={site.organization.url}>{ownerSiteLabel}</a>
        </p>
        <nav class="flex flex-wrap items-center gap-x-6 gap-y-2">
          <a href="/legal/privacy/">Privacy</a>
          <a href="/legal/terms/">Terms</a>
          <a href={`mailto:${site.contact.email}`}>Contact</a>
          <a href={site.social.github}>GitHub</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
