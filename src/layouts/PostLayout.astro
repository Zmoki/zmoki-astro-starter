---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import Time from "@/components/Time.astro";
import Prose from "@/components/Prose.astro";
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/site.config";
import { getOgImage } from "@/og/manifest";
import { siteUrls } from "@/lib/urls";

export interface Props {
  title: string;
  description?: string;
  publishDate: Date;
  contentModifiedDate: Date;
  author: CollectionEntry<"blog">["data"]["author"];
  /** Overrides the canonical URL — set for cross-posted content. See the blog schema. */
  canonical?: string;
  prevPost?: CollectionEntry<"blog"> | null;
  nextPost?: CollectionEntry<"blog"> | null;
}

const {
  title,
  description,
  publishDate,
  contentModifiedDate,
  author,
  canonical,
  prevPost,
  nextPost,
} = Astro.props;
const isContentModified = contentModifiedDate.getTime() > publishDate.getTime();

// BlogPosting structured data (schema.org Article) → Google rich result.
// Article has no required properties; we include the recommended ones the page
// actually backs up. All absolute URLs come from the shared siteUrls() helper
// (src/lib/urls.ts) — the same source BaseLayout uses for canonical + og:image —
// so the structured data can't drift from the meta tags. The image reuses the
// page's OG card via the manifest. See the /structured-data skill and Google's
// Article reference: https://developers.google.com/search/docs/appearance/structured-data/article
const urls = siteUrls(Astro);
const ogImage = await getOgImage(Astro.url.pathname);
const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  ...(description ? { description } : {}),
  datePublished: publishDate.toISOString(),
  dateModified: contentModifiedDate.toISOString(),
  author: {
    "@type": "Person",
    name: author.name,
    url: author.url,
  },
  publisher: {
    "@type": "Organization",
    name: site.organization.name,
    url: site.organization.url,
  },
  image: urls.absoluteUrl(ogImage.path),
  mainEntityOfPage: canonical ?? urls.absoluteUrl(Astro.url.pathname),
};
---

<BaseLayout
  title={title}
  description={description}
  publishDate={publishDate}
  contentModifiedDate={contentModifiedDate}
  canonical={canonical}
>
  <JsonLd schema={blogPostingLd} />
  <article class="space-y-4">
    <!-- Post Header -->
    <header
      class="border-zmoki-stone-200 flex flex-col gap-6 rounded-2xl border bg-white px-4 py-8 shadow-sm md:items-center md:p-16 md:text-center lg:p-20"
    >
      <h1 class="text-4xl font-semibold tracking-tight xl:text-6xl" set:html={title} />
      {
        description && (
          <p class="text-zmoki-stone-600 text-2xl xl:text-3xl" set:html={description} />
        )
      }
      <p class="text-zmoki-stone-500 order-first flex flex-col gap-2 text-sm md:flex-row lg:gap-4">
        {
          isContentModified ? (
            <>
              <span>
                Updated on <Time datetime={contentModifiedDate} />
              </span>
              <span>
                [published on <Time datetime={publishDate} />]
              </span>
            </>
          ) : (
            <span>
              Published on <Time datetime={publishDate} />
            </span>
          )
        }
      </p>
    </header>

    <!-- Post Content -->
    <Prose class="prose-xl xl:prose-2xl xl:px-28 xl:py-16">
      <slot />
    </Prose>

    <!-- About Author -->
    <aside
      class="border-zmoki-stone-200 text-zmoki-stone-900 md:border-zmoki-indigo-600 md:bg-zmoki-indigo-600 space-y-2 rounded-2xl border bg-white px-4 py-8 leading-normal shadow-sm md:p-16 md:text-white lg:p-20"
    >
      <h2 class="pb-4 text-3xl font-semibold xl:text-4xl">Written by {author.name}</h2>
      <p>
        {author.bio} Find more of my work at <a
          href={author.url}
          class="text-zmoki-indigo-600 font-medium underline underline-offset-2 md:text-white"
          >{new URL(author.url).host}</a
        >.
      </p>
    </aside>

    <!-- Navigation -->
    <nav class="grid w-full grid-cols-1 gap-4 md:grid-cols-2">
      <!-- Previous Post -->
      {
        prevPost && (
          <a
            href={`/blog/${prevPost.id}/`}
            data-nav-direction="prev"
            data-nav-slug={prevPost.id}
            class="border-zmoki-stone-200 border-l-zmoki-indigo-600 flex flex-col gap-2 rounded-2xl border border-l-4 bg-white px-6 pt-8 pb-10 shadow-sm transition-shadow hover:shadow-md"
          >
            <div class="text-zmoki-stone-500 text-sm font-medium">Previous</div>
            <div class="text-zmoki-stone-900 text-2xl leading-normal font-medium">
              <span set:html={prevPost.data.title} />
            </div>
          </a>
        )
      }

      <!-- Next Post -->
      {
        nextPost && (
          <a
            href={`/blog/${nextPost.id}/`}
            data-nav-direction="next"
            data-nav-slug={nextPost.id}
            class="border-zmoki-stone-200 border-r-zmoki-indigo-600 flex flex-col gap-2 rounded-2xl border border-r-4 bg-white px-6 pt-8 pb-10 text-right shadow-sm transition-shadow hover:shadow-md md:col-start-2"
          >
            <div class="text-zmoki-stone-500 text-sm font-medium">Next</div>
            <div class="text-zmoki-stone-900 text-2xl leading-normal font-medium">
              <span set:html={nextPost.data.title} />
            </div>
          </a>
        )
      }
    </nav>
  </article>

  <script is:inline>
    // Post-navigation tracking. (Code-block copy behavior lives in <Prose>.)
    document.querySelectorAll("a[data-nav-direction]").forEach(function (el) {
      el.addEventListener("click", function () {
        window.track?.("post_navigation_clicked", {
          direction: this.dataset.navDirection,
          destination_slug: this.dataset.navSlug,
        });
      });
    });
  </script>
</BaseLayout>
