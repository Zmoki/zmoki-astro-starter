---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Time from "@/components/Time.astro";
import BrevoForm from "@/components/BrevoForm.astro";

export interface Props {
  type: "page" | "link";
  title: string;
  description?: string;
  publishDate: Date;
  contentModifiedDate: Date;
  form?: {
    brevoFormId: string;
    buttonText: string;
    title: string;
    description: string;
  };
}

const { title, description, publishDate, contentModifiedDate, form } = Astro.props;
const isContentModified = contentModifiedDate.getTime() > publishDate.getTime();
---

<BaseLayout
  title={title}
  description={description}
  publishDate={publishDate}
  contentModifiedDate={contentModifiedDate}
>
  <article class="space-y-4">
    <!-- Post Header -->
    <header
      class="outline-zmoki-neutral-900 flex flex-col gap-6 rounded-xl bg-white px-4 py-8 outline-8 -outline-offset-2 outline-dashed md:items-center md:p-16 md:text-center lg:p-20 lg:pb-16"
    >
      <h1 class="text-5xl font-semibold xl:text-6xl" set:html={title} />
      {description && <p class="text-2xl xl:text-3xl" set:html={description} />}

      <p
        class="order-first flex flex-col gap-2 font-mono text-xs tracking-normal uppercase opacity-70 md:flex-row lg:gap-4 xl:text-sm"
      >
        <span>Published on <Time datetime={publishDate} /></span>
        {
          isContentModified && (
            <span>
              [updated on <Time datetime={contentModifiedDate} />]
            </span>
          )
        }
      </p>
    </header>

    <div class="flex flex-col gap-4">
      <!-- Post Content -->
      <div
        class="prose prose-xl border-zmoki-neutral-900 xl:prose-2xl prose-headings:font-semibold [&_a]:text-zmoki-neutral-900 max-w-none rounded-xl border-2 bg-white px-4 py-8 md:p-16 xl:px-32 xl:py-16"
      >
        <slot />
      </div>
      {
        form && (
          <div class="order-first">
            <BrevoForm brevoFormId={form.brevoFormId} buttonText={form.buttonText}>
              <h2 set:html={form.title} />
              <p set:html={form.description} />
              <p>
                You'll also join my occasional newsletter with new tools and ideas, you can
                unsubscribe at any time though.
              </p>
            </BrevoForm>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>
