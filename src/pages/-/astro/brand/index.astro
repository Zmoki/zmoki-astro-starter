---
import BrandLayout from "@/layouts/BrandLayout.astro";
import { colors, fonts } from "@/design-tokens.mjs";
import { site } from "@/site.config";

const cream = colors["zmoki-cream"] as Record<string, string>;
const stone = colors["zmoki-stone"] as Record<string, string>;
const indigo = colors["zmoki-indigo"] as Record<string, string>;

// The key colors of the system — warm ivory canvas, ink, muted text, and the
// indigo accent ramp — so the strip reads as a warm, minimal palette.
const palettePreview = [cream["100"], stone["900"], stone["500"], indigo["100"], indigo["600"]];

// Top-level brand settings, the files a rebrand starts from before any
// individual guideline page. Rendered between the hero and the section cards.
// A summary is a list of parts; a `{ code }` part renders as inline code.
const foundations: {
  title: string;
  file: string;
  summary: (string | { code: string })[];
  mark: boolean;
}[] = [
  {
    title: "Brand mark",
    file: "public/brand-mark.svg",
    summary: [
      "One square, full-bleed SVG sets the whole identity. It becomes the nav logo, the favicon set, and the mark on the OG cards. Replace it, then rerun ",
      { code: "npm run favicons" },
      ".",
    ],
    mark: true,
  },
  {
    title: "Site config",
    file: "src/site.config.ts",
    summary: [
      "Everything personal to the site lives here. The name, domain, nav links, owner, and contact. Right now that is ",
      `${site.name} at ${new URL(site.domain).host}.`,
    ],
    mark: false,
  },
  {
    title: "Design tokens",
    file: "src/design-tokens.mjs",
    summary: [
      "The color scales behind every ",
      { code: "zmoki-*" },
      ` utility, plus the fonts (${fonts.sans.name} and ${fonts.mono.name}). Tailwind and these brand pages read the same file, so nothing drifts.`,
    ],
    mark: false,
  },
];

// Sections of the design system. `href` null = not built yet.
const sections = [
  {
    title: "Color",
    summary: "A warm, minimal token system — ivory canvas and a single indigo accent.",
    href: "/-/astro/brand/color/",
    accent: "bg-zmoki-indigo-600",
  },
  {
    title: "Typography",
    summary: `${fonts.sans.name} throughout — one clean sans for headings, body, and labels.`,
    href: "/-/astro/brand/typography/",
    accent: "bg-zmoki-indigo-600",
  },
  {
    title: "Forms",
    summary: "Inputs, labels, the action button, focus and error states.",
    href: "/-/astro/brand/forms/",
    accent: "bg-zmoki-indigo-600",
  },
  {
    title: "Components",
    summary: "Nav, footer, hero, cards, links, and buttons as reusable blocks.",
    href: "/-/astro/brand/components/",
    accent: "bg-zmoki-indigo-600",
  },
  {
    title: "Voice & tone",
    summary: `How ${site.name} sounds. Clear, honest, helpful, human.`,
    href: "/-/astro/brand/voice/",
    accent: "bg-zmoki-indigo-600",
  },
  {
    title: "OG images",
    summary:
      "Social-share cards — the two card templates, their anatomy, and where they come from.",
    href: "/-/astro/brand/og/",
    accent: "bg-zmoki-indigo-600",
  },
];
---

<BrandLayout
  title={`Brand — ${site.name} design system`}
  description={`The brand and design system guideline for ${site.name}`}
>
  <header
    class="border-zmoki-stone-200 bg-zmoki-indigo-600 mb-8 overflow-hidden rounded-2xl border text-white shadow-sm"
  >
    <div class="px-6 py-10 md:px-10 md:py-14">
      <p class="text-zmoki-indigo-100 text-xs font-medium tracking-normal">{site.name}</p>
      <h1 class="mt-2 text-4xl font-semibold md:text-6xl">Design system</h1>
      <p class="mt-4 max-w-2xl text-xl md:text-2xl">
        The living guideline for how {site.name} looks and feels — a bright, warm, minimal system: an
        ivory canvas, soft white cards, and a single indigo accent. One source of truth for color, type,
        and components.
      </p>
    </div>
    <div class="flex h-3">
      {palettePreview.map((hex) => <span class="flex-1" style={`background-color: ${hex}`} />)}
    </div>
  </header>

  <section class="mb-8">
    <h2 class="text-2xl font-semibold md:text-3xl">Foundations</h2>
    <p class="text-zmoki-stone-500 mt-2 max-w-2xl">
      Before the guideline pages below, the brand is set in three top-level files. A rebrand starts
      here.
    </p>
    <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-3">
      {
        foundations.map((item) => (
          <div class="border-zmoki-stone-200 flex flex-col gap-3 rounded-2xl border bg-white p-6 shadow-sm">
            {item.mark ? (
              <img src="/brand-mark.svg" alt="Brand mark" class="h-10 w-10 rounded-lg" />
            ) : (
              <span class="bg-zmoki-indigo-600 h-2 w-12 self-start rounded-full" />
            )}
            <h3 class="text-xl font-semibold">{item.title}</h3>
            <code class="bg-zmoki-indigo-50 text-zmoki-indigo-700 self-start rounded px-2 py-1 font-mono text-xs">
              {item.file}
            </code>
            <p class="text-zmoki-stone-500 text-sm">
              {item.summary.map((part) =>
                typeof part === "string" ? (
                  part
                ) : (
                  <code class="bg-zmoki-cream-100 text-zmoki-stone-900 rounded px-1 py-0.5 font-mono text-xs">
                    {part.code}
                  </code>
                ),
              )}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {
      sections.map((section) =>
        section.href ? (
          <a
            href={section.href}
            class="group border-zmoki-stone-200 flex flex-col gap-3 rounded-2xl border bg-white p-6 shadow-sm transition-shadow hover:-translate-y-1 hover:shadow-md md:p-8"
          >
            <span class={`h-2 w-12 rounded-full ${section.accent}`} />
            <h2 class="text-2xl font-semibold md:text-3xl">
              <span class="text-zmoki-indigo-600 underline underline-offset-2">
                {section.title}
              </span>
            </h2>
            <p class="text-zmoki-stone-500">{section.summary}</p>
            <span class="text-zmoki-stone-500 mt-2 text-xs font-medium tracking-normal">
              View →
            </span>
          </a>
        ) : (
          <div class="border-zmoki-stone-300 flex flex-col gap-3 rounded-2xl border border-dashed bg-white/50 p-6 md:p-8">
            <span class={`h-2 w-12 rounded-full opacity-30 ${section.accent}`} />
            <h2 class="text-2xl font-semibold opacity-50 md:text-3xl">{section.title}</h2>
            <p class="opacity-50">{section.summary}</p>
            <span class="mt-2 text-xs font-medium tracking-normal opacity-40">Coming soon</span>
          </div>
        ),
      )
    }
  </div>
</BrandLayout>
