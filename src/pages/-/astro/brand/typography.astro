---
import BrandLayout from "@/layouts/BrandLayout.astro";
import { colors, fonts } from "@/design-tokens.mjs";
import { site } from "@/site.config";

// Pull real tokens so the link-treatment swatches can never drift from
// what Tailwind actually generates (mirrors the Color page approach).
const indigo = colors["zmoki-indigo"] as Record<string, string>;
const accent = indigo["600"];

// ---------------------------------------------------------------------------
// Part 1 — Design typography (UI type scale)
// Each step renders live with the exact utility classes used in the real
// layouts/components, so the specimen is the source of truth.
// ---------------------------------------------------------------------------
const typeScale = [
  {
    label: "Hero",
    classes: "text-4xl font-semibold xl:text-6xl",
    sample: site.name,
    usage: "Post titles (PostLayout h1)",
  },
  {
    label: "Lede",
    classes: "text-2xl xl:text-3xl",
    sample: "Ideas, art, and research, kept in the open.",
    usage: "Post descriptions (PostLayout)",
  },
  {
    label: "Section heading",
    classes: "text-3xl font-medium md:text-4xl",
    sample: "What you get",
    usage: "Landing sections & author bio (h2)",
  },
  {
    label: "Card title",
    classes: "text-2xl font-semibold leading-normal xl:text-3xl",
    sample: "An example post",
    usage: "PostCard (h3)",
  },
  {
    label: "Body",
    classes: "text-lg xl:text-xl",
    sample: `The base reading size — ${fonts.sans.name}, set clean.`,
    usage: "Global body (BaseLayout)",
  },
] as const;

// Mono-set UI labels — small, uppercase, tracked normal.
const monoLabels = [
  {
    label: "Eyebrow / meta",
    classes: "font-mono text-xs uppercase tracking-normal",
    sample: "20 Jun 2026",
    usage: "Dates, eyebrows (PostCard, PostLayout)",
  },
  {
    label: "Previous / Next",
    classes: "font-mono text-sm uppercase tracking-normal",
    sample: "Previous",
    usage: "Post navigation (PostLayout)",
  },
  {
    label: "Button text",
    classes: "font-mono text-xs font-medium uppercase tracking-normal",
    sample: "Copy",
    usage: "Copy / action buttons",
  },
] as const;

// Tracking & leading conventions — the analysis flagged drift between
// tracking-tight / -tighter / -normal. This documents the intended rule.
const trackingRules = [
  {
    token: "tracking-tight",
    rule: "Default — headings, body, nav & footer labels",
    where: "Global body, nav, footer",
  },
  {
    token: "tracking-normal",
    rule: "In-content mono labels — eyebrows, meta, buttons",
    where: "Dates, Previous/Next, copy button",
  },
];

const leadingRules = [
  { token: "leading-tight", rule: "Body copy & headings", where: "Global body (BaseLayout)" },
  { token: "leading-normal", rule: "Multi-line titles", where: "PostCard, prev/next titles" },
];

// ---------------------------------------------------------------------------
// Part 2 — Prose typography (MDX .prose content)
// Link treatments sourced from real tokens.
// ---------------------------------------------------------------------------
const linkTreatments = [
  {
    label: "Base link",
    attr: "a",
    color: accent,
    style: "underline offset-2",
    token: "zmoki-indigo-600",
  },
  {
    label: "External",
    attr: "[data-external]",
    color: accent,
    style: "underline offset-2",
    token: "zmoki-indigo-600",
  },
  {
    label: "Resource",
    attr: "[data-resource]",
    color: accent,
    style: "underline offset-2",
    token: "zmoki-indigo-600",
  },
  {
    label: "Anchor",
    attr: "[data-anchor]",
    color: accent,
    style: "underline offset-2",
    token: "zmoki-indigo-600",
  },
];
---

<BrandLayout
  title="Brand — Typography"
  description={`${site.name} typography scale and prose styles`}
>
  <header
    class="border-zmoki-stone-200 bg-zmoki-indigo-600 mb-8 rounded-2xl border px-6 py-10 text-white shadow-sm md:px-10"
  >
    <a href="/-/astro/brand/" class="text-xs text-white/70 hover:text-white">← {site.name} brand</a>
    <h1 class="mt-2 text-4xl font-semibold md:text-5xl">Typography</h1>
    <p class="mt-4 max-w-2xl text-xl md:text-2xl">
      Headings and body share one typeface: {fonts.sans.name}. Code uses {fonts.mono.name} — plus a tuned
      <code class="font-mono">.prose</code> layer for written content. Every specimen below renders with
      its real utility classes.
    </p>
  </header>

  <!-- ===================================================================== -->
  <!-- Part 1 — Design typography                                            -->
  <!-- ===================================================================== -->
  <h2 class="text-zmoki-stone-500 mb-4 px-1 text-sm font-medium">Part 1 · Design typography</h2>

  <!-- Font pairing -->
  <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-2">
    <section class="border-zmoki-stone-200 rounded-xl border bg-white p-6 shadow-sm md:p-8">
      <p class="text-zmoki-stone-500 text-xs font-medium">Headings &amp; body · font-sans</p>
      <p class="mt-2 font-sans text-5xl font-bold">{fonts.sans.name}</p>
      <p class="text-zmoki-stone-500 mt-3 text-lg">
        One typeface for everything — headings (h1–h6), UI labels, body copy, and prose. Variable
        weight, 100–900.
      </p>
      <p class="mt-4 font-sans text-2xl">AaBbCc 0123 — æ ß ç</p>
    </section>
    <section class="border-zmoki-stone-200 rounded-xl border bg-white p-6 shadow-sm md:p-8">
      <p class="text-zmoki-stone-500 text-xs font-medium">Code · font-mono</p>
      <p class="mt-2 font-mono text-5xl font-bold">{fonts.mono.name}</p>
      <p class="text-zmoki-stone-500 mt-3 text-lg">Code, tokens, and literal specimens.</p>
      <p class="mt-4 font-mono text-2xl">AaBbCc 0123 — æ ß ç</p>
    </section>
  </div>

  <!-- Type scale -->
  <section class="border-zmoki-stone-200 mb-6 rounded-xl border bg-white p-6 shadow-sm md:p-8">
    <h3 class="mb-5 text-2xl font-semibold md:text-3xl">Type scale</h3>
    <div class="divide-zmoki-stone-200 divide-y">
      {
        typeScale.map((step) => (
          <div class="grid items-baseline gap-2 py-5 md:grid-cols-[10rem_1fr]">
            <div>
              <p class="font-medium">{step.label}</p>
              <p class="text-zmoki-stone-500 mt-1 text-xs">{step.usage}</p>
            </div>
            <div>
              <p class={step.classes}>{step.sample}</p>
              <p class="text-zmoki-stone-500 mt-2 font-mono text-xs lowercase">{step.classes}</p>
            </div>
          </div>
        ))
      }
    </div>

    <h3 class="mt-8 mb-5 text-2xl font-semibold md:text-3xl">Mono labels</h3>
    <div class="divide-zmoki-stone-200 divide-y">
      {
        monoLabels.map((step) => (
          <div class="grid items-baseline gap-2 py-5 md:grid-cols-[10rem_1fr]">
            <div>
              <p class="font-medium">{step.label}</p>
              <p class="text-zmoki-stone-500 mt-1 text-xs">{step.usage}</p>
            </div>
            <div>
              <p class={step.classes}>{step.sample}</p>
              <p class="text-zmoki-stone-500 mt-2 font-mono text-xs lowercase">{step.classes}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Tracking & leading -->
  <div class="mb-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
    <section class="border-zmoki-stone-200 rounded-xl border bg-white p-6 shadow-sm md:p-8">
      <h3 class="mb-4 text-2xl font-semibold">Tracking</h3>
      <ul class="space-y-4">
        {
          trackingRules.map((r) => (
            <li>
              <code class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono text-sm font-medium">
                {r.token}
              </code>
              <p class="text-zmoki-stone-700 mt-1 text-base">{r.rule}</p>
              <p class="text-zmoki-stone-500 text-xs">{r.where}</p>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="border-zmoki-stone-200 rounded-xl border bg-white p-6 shadow-sm md:p-8">
      <h3 class="mb-4 text-2xl font-semibold">Leading</h3>
      <ul class="space-y-4">
        {
          leadingRules.map((r) => (
            <li>
              <code class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono text-sm font-medium">
                {r.token}
              </code>
              <p class="text-zmoki-stone-700 mt-1 text-base">{r.rule}</p>
              <p class="text-zmoki-stone-500 text-xs">{r.where}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </div>

  <!-- ===================================================================== -->
  <!-- Part 2 — Prose typography                                             -->
  <!-- ===================================================================== -->
  <h2 class="text-zmoki-stone-500 mb-4 px-1 text-sm font-medium">Part 2 · Prose typography</h2>

  <!-- Prose config -->
  <section class="border-zmoki-stone-200 mb-6 rounded-xl border bg-white p-6 shadow-sm md:p-8">
    <h3 class="mb-4 text-2xl font-semibold md:text-3xl">.prose configuration</h3>
    <p class="text-zmoki-stone-700 mb-4">
      MDX content renders inside <code
        class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono"
        >prose prose-xl</code
      > (stepping up to
      <code class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono"
        >2xl:prose-2xl</code
      >). Overrides live in
      <code class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono"
        >tailwind.config.mjs</code
      > via <code class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono"
        >typography()</code
      >.
    </p>
    <ul
      class="border-zmoki-indigo-100 bg-zmoki-indigo-50 text-zmoki-stone-700 space-y-2 rounded-xl border p-4 font-mono text-sm"
    >
      <li>
        <span class="text-zmoki-stone-900">--tw-prose-headings</span>
        <span class="text-zmoki-stone-500">→ zmoki-stone-900</span>
      </li>
      <li>
        <span class="text-zmoki-stone-900">--tw-prose-body</span>
        <span class="text-zmoki-stone-500">→ zmoki-stone-900</span>
      </li>
      <li>
        <span class="text-zmoki-stone-900">--tw-prose-bold</span>
        <span class="text-zmoki-stone-500">→ zmoki-stone-900</span>
      </li>
      <li>
        <span class="text-zmoki-stone-900">prose-headings:font-semibold</span>
        <span class="text-zmoki-stone-500">→ heading weight (PostLayout)</span>
      </li>
    </ul>
  </section>

  <!-- Link treatments -->
  <section class="border-zmoki-stone-200 mb-6 rounded-xl border bg-white p-6 shadow-sm md:p-8">
    <h3 class="mb-5 text-2xl font-semibold md:text-3xl">In-prose links</h3>
    <p class="text-zmoki-stone-700 mb-5">
      Link treatment is driven by data attributes added by the <code
        class="bg-zmoki-stone-100 text-zmoki-stone-800 rounded px-1.5 py-0.5 font-mono"
        >rehypeExternalLinks</code
      > plugin. Each renders with its real token.
    </p>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        linkTreatments.map((link) => (
          <div class="border-zmoki-stone-200 rounded-xl border p-4">
            <span
              class="text-lg font-medium underline underline-offset-2"
              style={`color: ${link.color};`}
            >
              {link.label}
            </span>
            <p class="text-zmoki-stone-500 mt-3 font-mono text-xs">{link.attr}</p>
            <p class="text-zmoki-stone-500 text-xs">
              {link.token} · {link.style}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Live prose specimen -->
  <section class="mb-10">
    <h3 class="mb-4 px-1 text-2xl font-semibold md:text-3xl">Live specimen</h3>
    <div
      class="prose prose-xl border-zmoki-stone-200 prose-headings:font-semibold max-w-none rounded-2xl border bg-white px-4 py-8 shadow-sm md:p-12"
    >
      <h1>The shape of a sentence</h1>
      <p>
        Prose body and headings are both set in {fonts.sans.name} at <code>prose-xl</code>, with <strong
          >ink-colored bold</strong
        >. This is a base <a href="/">internal link</a>, an
        <a href="https://example.com" data-external="true">external link</a>, a
        <a href="/resources/" data-resource="true">resource link</a>, and an
        <a href="#lists" data-anchor="true">anchor link</a>.
      </p>
      <h2 id="lists">Lists</h2>
      <ul>
        <li>Unordered items use the prose default marker.</li>
        <li>Inline <code>code</code> picks up the mono face.</li>
      </ul>
      <ol>
        <li>Ordered items count up.</li>
        <li>Then carry on.</li>
      </ol>
      <blockquote>
        <p>A blockquote sets quoted material apart with a left rule and italic body.</p>
      </blockquote>
      <h2>Definition list</h2>
      <dl>
        <dt>Design token</dt>
        <dd>A named value (like a color) defined once and reused everywhere.</dd>
        <dt>Definition list</dt>
        <dd>A term paired with its description, like this one.</dd>
      </dl>
      <h2>Code block</h2>
      <p>
        Fenced blocks are highlighted with Shiki (<code>catppuccin-latte</code>) and get a copy
        button at build time. Hand-written here, they fall back to prose code styling:
      </p>
      <pre><code>const garden = ["posts", "resources", "now"];
garden.forEach((bed) =&gt; tend(bed));</code></pre>
    </div>
  </section>
</BrandLayout>
