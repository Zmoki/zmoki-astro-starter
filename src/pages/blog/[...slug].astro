---
import { getCollection, render, type CollectionEntry } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import { getPostsNewestFirst } from "@/lib/page-collections";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props as CollectionEntry<"blog">;
const { Content } = await render(post);

// Prev/next navigation over the shared newest-first ordering.
const sortedPosts = await getPostsNewestFirst();
const currentIndex = sortedPosts.findIndex((p: CollectionEntry<"blog">) => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  publishDate={post.data.publishDate}
  contentModifiedDate={post.data.contentModifiedDate}
  author={post.data.author}
  cover={post.data.cover}
  canonical={post.data.canonical}
  prevPost={prevPost}
  nextPost={nextPost}
  robots={post.data.robots}
>
  <Content />
</PostLayout>

<script is:inline define:vars={{ postSlug: post.id, postTitle: post.data.title }}>
  window.track?.("post_viewed", {
    post_slug: postSlug,
    post_title: postTitle,
  });
</script>
