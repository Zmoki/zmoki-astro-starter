---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/site.config";

// Kept for the sitemap (src/pages/sitemap.xml.ts imports these).
export const publishDate = new Date("2025-01-01");
export const contentModifiedDate = new Date("2025-01-01");

// Placeholder features — edit, extend, or remove.
const features = [
  {
    title: "Fast by default",
    text: "Astro ships zero JavaScript by default, so pages load instantly. Add interactivity only where you actually need it.",
  },
  {
    title: "Yours in one file",
    text: "Everything site-specific lives in src/site.config.ts. Change it once and the whole site follows.",
  },
  {
    title: "Ready to grow",
    text: "A blog, resources, RSS, analytics, and email forms are already wired up and waiting for your content.",
  },
];
---

<BaseLayout title={`${site.name} — ${site.hero.heading}`} description={site.description} wide>
  <!-- Hero -->
  <section class="px-4 py-16 text-center lg:py-28">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-5xl font-semibold tracking-tight md:text-6xl">{site.hero.heading}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-xl text-zmoki-neutral-600 md:text-2xl">
        {site.hero.subhead}
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href={site.cta.href}
          class="border-2 border-zmoki-neutral-900 bg-zmoki-neutral-900 px-6 py-3 font-mono text-base font-bold uppercase tracking-tight text-slate-50"
          >{site.cta.label}</a
        >
        <a
          href="/blog/"
          class="border-2 border-zmoki-neutral-900 bg-white px-6 py-3 font-mono text-base font-bold uppercase tracking-tight text-zmoki-neutral-900"
          >Read the blog →</a
        >
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="scroll-mt-20 px-4 py-16 lg:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-3xl font-semibold md:text-4xl">What you get</h2>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          features.map((feature) => (
            <div class="rounded-xl border-2 border-zmoki-neutral-900 bg-white p-8">
              <h3 class="text-xl font-semibold">{feature.title}</h3>
              <p class="mt-3 text-base text-zmoki-neutral-600">{feature.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="cta" class="scroll-mt-20 px-4 pb-20 pt-4">
    <div
      class="mx-auto max-w-6xl rounded-2xl border-2 border-zmoki-neutral-900 bg-zmoki-neutral-900 px-6 py-16 text-center text-slate-50 md:py-20"
    >
      <h2 class="text-3xl font-semibold md:text-4xl">{site.finalCta.heading}</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-50/90">{site.finalCta.text}</p>
      <a
        href={site.finalCta.button.href}
        class="mt-8 inline-block border-2 border-white bg-white px-6 py-3 font-mono text-base font-bold uppercase tracking-tight text-zmoki-neutral-900"
        >{site.finalCta.button.label}</a
      >
    </div>
  </section>
</BaseLayout>
