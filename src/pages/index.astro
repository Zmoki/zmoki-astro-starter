---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/Button.astro";
import { site } from "@/site.config";

// The landing page's publish/modified dates live in src/data/home-page.ts so the
// sitemap can read them without importing from this page component.

// Placeholder features — edit, extend, or remove.
const features = [
  {
    title: "Fast by default",
    text: "Astro ships zero JavaScript by default, so pages load instantly. Add interactivity only where you actually need it.",
  },
  {
    title: "Yours in one file",
    text: "Everything site-specific lives in src/site.config.ts. Change it once and the whole site follows.",
  },
  {
    title: "Ready to grow",
    text: "A blog, resources, RSS, analytics, and email forms are already wired up and waiting for your content.",
  },
];
---

<BaseLayout title={`${site.name} — ${site.hero.heading}`} description={site.description} wide>
  <!-- Hero -->
  <section class="px-4 py-16 text-center lg:py-28">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-5xl font-semibold tracking-tight md:text-6xl">{site.hero.heading}</h1>
      <p class="text-zmoki-stone-600 mx-auto mt-6 max-w-2xl text-xl md:text-2xl">
        {site.hero.subhead}
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <Button href={site.cta.href} size="lg">{site.cta.label}</Button>
        <Button href="/blog/" variant="secondary" size="lg">Read the blog →</Button>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="scroll-mt-20 px-4 py-16 lg:py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center text-3xl font-semibold md:text-4xl">What you get</h2>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          features.map((feature) => (
            <div class="border-zmoki-stone-200 rounded-2xl border bg-white p-8 shadow-sm transition-shadow hover:shadow-md">
              <h3 class="text-xl font-semibold">{feature.title}</h3>
              <p class="text-zmoki-stone-600 mt-3 text-base">{feature.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="cta" class="scroll-mt-20 px-4 pt-4 pb-20">
    <div
      class="bg-zmoki-indigo-600 mx-auto max-w-6xl rounded-3xl px-6 py-16 text-center text-white shadow-sm md:py-20"
    >
      <h2 class="text-3xl font-semibold md:text-4xl">{site.finalCta.heading}</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-white/90">{site.finalCta.text}</p>
      <Button href={site.finalCta.button.href} variant="inverse" size="lg" class="mt-8">
        {site.finalCta.button.label}
      </Button>
    </div>
  </section>
</BaseLayout>
