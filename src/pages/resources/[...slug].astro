---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ResourceLayout from "@/layouts/ResourceLayout.astro";
import { isResourcePage } from "@/lib/page-collections";

export async function getStaticPaths() {
  const items: CollectionEntry<"resources">[] = await getCollection("resources", isResourcePage);

  return items.map((item) => ({
    params: { slug: item.id },
    props: item,
  }));
}

const item = Astro.props as CollectionEntry<"resources">;
const { Content } = await render(item);
---

<ResourceLayout {...item.data} slug={item.id}><Content /></ResourceLayout>
